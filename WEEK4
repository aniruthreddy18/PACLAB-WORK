        "class CSP:\n",
        "    def __init__(self, variables, domains, constraints):\n",
        "        self.variables = variables\n",
        "        self.domains = domains\n",
        "        self.constraints = constraints\n",
        "    def is_consistent(self, var, val, assignment):\n",
        "        return all(c(var, val, assignment)\n",
        "                   for c in self.constraints.get(var, []))\n",
        "    def backtrack(self, assignment={}):\n",
        "        if len(assignment) == len(self.variables):\n",
        "            return assignment\n",
        "        var = next(v for v in self.variables if v not in assignment)\n",
        "        for val in self.domains[var]:\n",
        "            if self.is_consistent(var, val, assignment):\n",
        "                assignment[var] = val\n",
        "                result = self.backtrack(assignment)\n",
        "                if result: return result\n",
        "                assignment.pop(var)\n",
        "        return None\n",
        "variables = ['A', 'B', 'C']\n",
        "domains = {'A':[1,2,6], 'B':[1,2,6], 'C':[6,6,6]}\n",
        "constraints = {\n",
        "    'A':[lambda v,val,a: 'B' not in a or a['B']!=val],\n",
        "    'B':[lambda v,val,a: 'A' not in a or a['A']!=val],\n",
        "    'C':[lambda v,val,a: 'A' not in a or a['A']!=val]}\n",
        "csp = CSP(variables, domains, constraints)\n",
        "sol = csp.backtrack({})\n",
        "if sol:\n",
        "    print(\"Solution:\", sol)\n",
        "else:\n",
        "    print(\"No solution found\")\n"
      ]
