      "source": [
        "# Assuming 'sol' is the dictionary containing the solution\n",
        "# For example: sol = {'A': 1, 'B': 2, 'C': 6}\n",
        "\n",
        "G = nx.Graph()\n",
        "\n",
        "# Add nodes for each variable and store its value as a node attribute\n",
        "for var, val in sol.items():\n",
        "    G.add_node(var, value=val)\n",
        "\n",
        "# Define node positions for better visualization (circular layout is often good for simple graphs)\n",
        "pos = nx.circular_layout(G)\n",
        "\n",
        "plt.figure(figsize=(8, 6))\n",
        "\n",
        "# Draw nodes\n",
        "nx.draw_networkx_nodes(G, pos, node_color='lightblue', node_size=2000)\n",
        "\n",
        "# Create labels dictionary (variable name: variable name + value)\n",
        "labels = {node: f\"{node}: {G.nodes[node]['value']}\" for node in G.nodes()}\n",
        "\n",
        "# Draw node labels\n",
        "nx.draw_networkx_labels(G, pos, labels, font_size=12, font_weight='bold')\n",
        "\n",
        "plt.title('CSP Solution: Node Representation', size=15)\n",
        "plt.axis('off') # Hide axes\n",
        "plt.show()"
